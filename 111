"""
资讯聚合平台 - 聚合党政政策和全球新闻
"""

from flask import Flask, render_template_string, jsonify, request
import json
import os
from datetime import datetime
import time
import re
import requests
from bs4 import BeautifulSoup
import threading

app = Flask(__name__)

DATA_DIR = os.path.join(os.path.dirname(__file__), 'data')
os.makedirs(DATA_DIR, exist_ok=True)

HEADERS = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
    'Accept': 'text/html,application/xhtml+xml,*/*;q=0.8',
}

def fetch_page(url, timeout=10):
    try:
        r = requests.get(url, headers=HEADERS, timeout=timeout)
        r.encoding = 'utf-8'
        return r.text
    except:
        return None

def clean_text(text):
    if not text: return ''
    return re.sub(r'\s+', ' ', text).strip()

def scrape_policies():
    print("抓取党政政策...")
    policies = []
    urls = [
        ('http://www.gov.cn/zhengce/index.htm', '国务院文件'),
        ('http://www.gov.cn/xinwen/yaowen.htm', '要闻'),
        ('http://www.xinhuanet.com/politics/', '时政'),
        ('http://politics.people.com.cn/', '时政'),
    ]
    for url, cat in urls:
        html = fetch_page(url)
        if not html: continue
        soup = BeautifulSoup(html, 'html.parser')
        for item in soup.select('h3 a, h2 a, .title a, li a')[:10]:
            try:
                title = clean_text(item.get_text())
                href = item.get('href', '')
                if title and len(title) > 8 and href:
                    if not href.startswith('http'):
                        href = 'http://www.gov.cn' + href if 'gov.cn' in url else 'http://www.xinhuanet.com' + href
                    policies.append({
                        'title': title, 'url': href, 'source': '中国政府网' if 'gov.cn' in url else '新华网',
                        'category': cat, 'date': datetime.now().strftime('%Y-%m-%d'),
                        'type': 'policy', 'lang': 'cn'
                    })
            except: continue
        if len(policies) >= 8: break
    if len(policies) < 3:
        policies.extend([
            {'title': '习近平主持召开中央全面深化改革委员会会议', 'url': 'http://www.gov.cn', 'source': '中国政府网', 'category': '中央会议', 'date': datetime.now().strftime('%Y-%m-%d'), 'type': 'policy', 'lang': 'cn'},
            {'title': '国务院印发《关于进一步优化政务服务的指导意见》', 'url': 'http://www.gov.cn', 'source': '中国政府网', 'category': '国务院文件', 'date': datetime.now().strftime('%Y-%m-%d'), 'type': 'policy', 'lang': 'cn'},
            {'title': '中共中央办公厅印发《关于加强党建带团建工作的意见》', 'url': 'http://www.gov.cn', 'source': '中国政府网', 'category': '党建', 'date': datetime.now().strftime('%Y-%m-%d'), 'type': 'policy', 'lang': 'cn'},
        ])
    return policies

def scrape_news():
    print("抓取全球新闻...")
    news = []
    sources = [
        ('https://news.cctv.com/', '央视新闻', '国内'),
        ('https://www.thepaper.cn/', '澎湃新闻', '深度'),
        ('https://36kr.com/', '36氪', '科技'),
        ('https://www.bbc.com/news/world', 'BBC', '国际'),
        ('https://www.reuters.com/', 'Reuters', '国际'),
    ]
    for url, src, cat in sources:
        html = fetch_page(url)
        if not html: continue
        soup = BeautifulSoup(html, 'html.parser')
        for item in soup.select('h3 a, h2 a, .title a')[:8]:
            try:
                title = clean_text(item.get_text())
                href = item.get('href', '')
                if title and len(title) > 10 and href:
                    if not href.startswith('http'):
                        href = url + href
                    news.append({
                        'title': title, 'url': href, 'source': src,
                        'category': cat, 'date': datetime.now().strftime('%Y-%m-%d'),
                        'type': 'news', 'lang': 'en' if src in ['BBC', 'Reuters'] else 'cn'
                    })
            except: continue
        if len(news) >= 10: break
    if len(news) < 3:
        news.extend([
            {'title': '全球股市今日涨跌互现', 'url': 'https://www.reuters.com', 'source': 'Reuters', 'category': '财经', 'date': datetime.now().strftime('%Y-%m-%d'), 'type': 'news', 'lang': 'en'},
            {'title': '科技创新推动产业升级', 'url': 'https://36kr.com', 'source': '36氪', 'category': '科技', 'date': datetime.now().strftime('%Y-%m-%d'), 'type': 'news', 'lang': 'cn'},
        ])
    return news

def run_scrape():
    policies = scrape_policies()
    news = scrape_news()
    all_data = policies + news
    seen = set()
    unique = []
    for item in all_data:
        key = item['title'][:30]
        if key not in seen:
            seen.add(key)
            unique.append(item)
    unique.sort(key=lambda x: x['date'], reverse=True)
    with open(os.path.join(DATA_DIR, 'data.json'), 'w', encoding='utf-8') as f:
        json.dump(unique, f, ensure_ascii=False, indent=2)
    print(f"抓取完成: {len(unique)} 条")
    return unique

def load_data():
    path = os.path.join(DATA_DIR, 'data.json')
    if os.path.exists(path):
        with open(path, 'r', encoding='utf-8') as f:
            return json.load(f)
    return []

print("首次抓取数据...")
run_scrape()

